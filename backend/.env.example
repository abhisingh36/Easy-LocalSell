# ─────────────────────────────────────────────────────────────
#  EASY Marketplace — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env file to git.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get from: mongodb.com → Your Project → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
# Change this to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string

# ── Gmail SMTP (for real email OTPs) ─────────────────────────
# Setup guide (5 minutes):
#
#  1. Go to myaccount.google.com
#  2. Security → 2-Step Verification (enable it first)
#  3. Security → App Passwords
#  4. Select "Mail" → Generate
#  5. Copy the 16-character password (format: xxxx xxxx xxxx xxxx)
#  6. Paste it below (spaces are fine)
#
# Without these, the app runs in DEV MODE:
#   - OTPs are returned in the API response
#   - OTPs are shown on the signup screen (good for testing)
#   - No real emails are sent

EMAIL_USER=youremail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Optional: Twilio SMS (NOT required — email OTP is used) ──
# Left here for future SMS notification features.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
